<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Task Flow • Tasks</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%
    const selectedStatus   = typeof currentStatus   !== 'undefined' ? currentStatus   : 'All';
    const selectedPriority = typeof currentPriority !== 'undefined' ? currentPriority : 'All';
    const searchText       = typeof search          !== 'undefined' ? search          : '';
    const backTo           = typeof returnTo        !== 'undefined' ? returnTo        : '/tasks';
    const safeTeamMembers  = typeof teamMembers !== 'undefined' && Array.isArray(teamMembers) ? teamMembers : [];

    const canWriteTasksFlag   = typeof canWriteTasks !== 'undefined' ? canWriteTasks : permissions?.canWriteTasks;
    const canManageUsersRoles = permissions?.canManageUsersRoles;
    const canManageTeams      = permissions?.canManageTeams;

    const currentWorkspace = typeof workspaceView !== 'undefined' ? workspaceView : 'personal';
    const isAdmin          = currentWorkspace === 'admin';
    const isTeamWorkspace  = currentWorkspace === 'team';
    const isTeamLeader     = isTeamWorkspace && roleName === 'Team Leader';
    const isMember         = isTeamWorkspace && roleName === 'Member';
    const isPersonal       = currentWorkspace === 'personal';
    const pathName         = typeof currentPath === 'string' ? currentPath : '';
    const isCurrent        = (targetPath) => pathName === targetPath;

    // Personal workspace users can always manage their own tasks.
    // In team workspace, members remain view-only.
    const canModifyTasks = isPersonal || (canWriteTasksFlag && !isMember);
  %>

  <h1>
    <% if (isAdmin)      { %>All Tasks<% } %>
    <% if (isTeamWorkspace) { %>Team Tasks<% } %>
    <% if (isPersonal)   { %>My To-Do List<% } %>
  </h1>

  <% if (error)   { %><p class="auth-error"   style="width:min(960px,100%);margin:0 auto 10px;"><%= error   %></p><% } %>
  <% if (message) { %><p class="auth-success" style="width:min(960px,100%);margin:0 auto 10px;"><%= message %></p><% } %>

  <div class="top-nav">
    <a href="/home" class="clear-link <%= isCurrent('/home') ? 'active' : '' %>" <%= isCurrent('/home') ? 'aria-current="page"' : '' %>>Home</a>
    <a href="/tasks" class="clear-link <%= isCurrent('/tasks') ? 'active' : '' %>" <%= isCurrent('/tasks') ? 'aria-current="page"' : '' %>>Tasks</a>
    <% if (isAdmin) { %>
      <a href="/admin/logs" class="clear-link <%= isCurrent('/admin/logs') ? 'active' : '' %>" <%= isCurrent('/admin/logs') ? 'aria-current="page"' : '' %>>System Logs</a>
    <% } %>
    <form action="/logout" method="POST" class="logout-inline">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>" />
      <button type="submit" class="clear-btn">Logout</button>
    </form>
  </div>

  <%# â”€â”€ Member read-only banner â”€â”€ %>
  <% if (isMember) { %>
    <div class="member-notice" style="width:min(960px,100%);margin:0 auto 14px;">
      <span>&#128065; You are viewing tasks assigned to you. Only your Team Leader can add, edit, or delete tasks.</span>
    </div>
  <% } %>

  <%# â”€â”€ Filter form â”€â”€ %>
  <form action="/tasks" method="GET" class="task-form filter-form">
    <select name="status">
      <option value="All"         <%= selectedStatus === 'All'         ? 'selected' : '' %>>All Statuses</option>
      <option value="Pending"     <%= selectedStatus === 'Pending'     ? 'selected' : '' %>>Pending</option>
      <option value="In Progress" <%= selectedStatus === 'In Progress' ? 'selected' : '' %>>In Progress</option>
      <option value="Completed"   <%= selectedStatus === 'Completed'   ? 'selected' : '' %>>Completed</option>
    </select>
    <select name="priority">
      <option value="All"    <%= selectedPriority === 'All'    ? 'selected' : '' %>>All Priorities</option>
      <option value="High"   <%= selectedPriority === 'High'   ? 'selected' : '' %>>High</option>
      <option value="Medium" <%= selectedPriority === 'Medium' ? 'selected' : '' %>>Medium</option>
      <option value="Low"    <%= selectedPriority === 'Low'    ? 'selected' : '' %>>Low</option>
    </select>
    <input type="text" name="q" value="<%= searchText %>" placeholder="Search tasks..." />
    <button type="submit">Filter</button>
    <button type="button" id="clearFiltersBtn" class="clear-btn">Clear</button>
  </form>

  <%# â”€â”€ Add task â€” personal, team leaders, admins only â”€â”€ %>
  <% if (canModifyTasks) { %>
    <form action="/add" method="POST" class="task-form">
      <input type="hidden" name="returnTo" value="<%= backTo %>" />
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>" />
      <input type="text" name="title"
        placeholder="<%= isTeamLeader ? 'New task for the team...' : 'Enter a new task...' %>"
        required />
      <select name="status">
        <option value="Pending">Pending</option>
        <option value="In Progress">In Progress</option>
        <option value="Completed">Completed</option>
      </select>
      <select name="priority">
        <option value="High">High Priority</option>
        <option value="Medium" selected>Medium Priority</option>
        <option value="Low">Low Priority</option>
      </select>
      <input type="date" name="due_date" />
      <% if (isTeamLeader || isAdmin) { %>
        <select name="assignee_user_id">
          <option value="">Assign to...</option>
          <% if (!safeTeamMembers.length) { %>
            <option value="" disabled>No team members available</option>
          <% } else { %>
            <% safeTeamMembers.forEach(member => { %>
              <option value="<%= member.id %>"><%= member.username %> (<%= member.email %>)</option>
            <% }) %>
          <% } %>
        </select>
      <% } %>
      <button type="submit"><%= isTeamLeader ? 'Assign Task' : 'Add Task' %></button>
    </form>
  <% } %>

  <%# â”€â”€ Tasks table â”€â”€ %>
  <table>
    <thead>
      <tr>
        <% if (canModifyTasks) { %><th>Done</th><% } %>
        <th>Task</th>
        <th>Priority</th>
        <th>Due Date</th>
        <% if (isAdmin || isTeamLeader) { %><th>Assigned To</th><% } %>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!tasks.length) { %>
        <tr>
          <td colspan="<%= canModifyTasks ? ((isAdmin || isTeamLeader) ? 7 : 6) : ((isAdmin || isTeamLeader) ? 6 : 5) %>"
              class="empty-state">
            <% if (isMember) { %>No tasks assigned to you yet.<% } else { %>No tasks yet. Add your first task above.<% } %>
          </td>
        </tr>
      <% } %>

      <% tasks.forEach(task => { %>
        <tr>
          <% if (canModifyTasks) { %>
            <td>
              <form action="/complete/<%= task.id %>" method="POST">
                <input type="hidden" name="returnTo" value="<%= backTo %>" />
                <input type="hidden" name="csrf_token" value="<%= csrfToken %>" />
                <input type="checkbox" onchange="this.form.submit()"
                  <%= task.status === 'Completed' ? 'checked disabled' : '' %> />
              </form>
            </td>
          <% } %>

          <td class="<%= task.status === 'Completed' ? 'done-task' : '' %>"><%= task.title %></td>

          <td>
            <span class="<%= task.priority === 'High' ? 'prio-high' : task.priority === 'Low' ? 'prio-low' : 'prio-medium' %>">
              <%= task.priority || 'Medium' %>
            </span>
          </td>

          <td><%= task.due_date ? String(task.due_date).slice(0,10) : '-' %></td>

          <% if (isAdmin || isTeamLeader) { %>
            <td><%= task.assignee_username || '-' %></td>
          <% } %>

          <td>
            <span class="status <%= task.status === 'Completed' ? 'completed' : task.status === 'In Progress' ? 'inprogress' : 'pending' %>">
              <%= task.status %>
            </span>
          </td>

          <td>
            <% if (canModifyTasks) { %>
              <a href="/edit/<%= task.id %>?returnTo=<%= encodeURIComponent(backTo) %>" class="edit">Edit</a>
              <form action="/delete/<%= task.id %>" method="POST" style="display:inline;">
                <input type="hidden" name="returnTo" value="<%= backTo %>" />
                <input type="hidden" name="csrf_token" value="<%= csrfToken %>" />
                <button type="submit" class="delete" onclick="return confirm('Delete this task?')">Delete</button>
              </form>
            <% } else { %>
              <span style="color:var(--text-muted);font-size:0.82rem;">View only</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <footer class="site-footer">
    <p>
      Task Flow
      <% if (isAdmin) { %>
        | <a href="/home">Home</a>
        | <a href="/admin/logs">System Logs</a>
      <% } else if (isTeamWorkspace) { %>
        | <a href="/home">Home</a>
        | <a href="/home">Team Home</a>
      <% } else { %>
        | <a href="/home">Home</a>
      <% } %>
    </p>
    <% if (!isAdmin) { %>
      <form action="/account/close" method="POST" class="footer-close-form">
        <input type="hidden" name="csrf_token" value="<%= csrfToken %>" />
        <button type="submit" class="delete"
          onclick="return confirm('Close your account? Admin can reopen it later.')">
          Close My Account
        </button>
      </form>
    <% } %>
  </footer>
  <script src="/buttons.js"></script>
</body>
</html>

