<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Task Flow • Set New Password</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="auth-page">
  <main class="auth-shell">
    <div class="top-nav" style="margin-top:0;">
      <a href="#" class="clear-link js-back-link" data-fallback="/login">Back</a>
    </div>
    <section class="auth-card">
      <h1>Set New Password</h1>
      <p>Create a new password for your account.</p>

      <% if (error) { %>
        <p class="auth-error"><%= error %></p>
      <% } %>
      <% if (message) { %>
        <p class="auth-success"><%= message %></p>
      <% } %>

      <form action="/reset-password/confirm" method="POST" class="task-form auth-form">
        <input type="hidden" name="token" value="<%= token %>" />

        <label for="password">New Password</label>
        <input id="password" type="password" name="password" minlength="8" placeholder="At least 8 characters" required />

        <label for="confirm_password">Confirm New Password</label>
        <input id="confirm_password" type="password" name="confirm_password" minlength="8" placeholder="Repeat your new password" required />

        <button type="submit">Update Password</button>
      </form>

      <p class="auth-helper">
        Back to <a href="/login">Login</a>.
      </p>
    </section>
  </main>
  <script src="/buttons.js"></script>
</body>
</html>



