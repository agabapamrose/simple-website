<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Task Flow • Reset Password</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="auth-page">
  <% const safeResetLink = typeof resetLink === "string" ? resetLink : ""; %>
  <main class="auth-shell">
    <div class="top-nav" style="margin-top:0;">
      <a href="#" class="clear-link js-back-link" data-fallback="/login">Back</a>
    </div>
    <section class="auth-card">
      <h1>Reset Password</h1>
      <p>Enter your email to generate a secure password reset link.</p>

      <% if (error) { %>
        <p class="auth-error"><%= error %></p>
      <% } %>
      <% if (message) { %>
        <p class="auth-success"><%= message %></p>
      <% } %>

      <form action="/reset-password" method="POST" class="task-form auth-form">
        <label for="email">Email</label>
        <input id="email" type="email" name="email" placeholder="you@example.com" required />

        <button type="submit">Generate Reset Link</button>
      </form>

      <% if (safeResetLink) { %>
        <p class="auth-helper">Reset Link:</p>
        <p class="auth-link-shell">
          <a href="<%= safeResetLink %>"><%= safeResetLink %></a>
        </p>
      <% } %>

      <p class="auth-helper">
        Remembered it? <a href="/login">Back to login</a>.
      </p>
    </section>
  </main>
  <script src="/buttons.js"></script>
</body>
</html>



